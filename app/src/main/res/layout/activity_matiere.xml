<LinearLayout xmlns:android="http://schemas.android.com/apk/res/android"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:orientation="vertical"
    android:padding="16dp"
    android:background="#F5F6FA">

    <TextView
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:text="Gestion des Matières"
        android:textSize="22sp"
        android:textStyle="bold"
        android:gravity="center"
        android:padding="10dp"
        android:textColor="#2C3E50"/>

    <EditText
        android:id="@+id/etNom"
        android:hint="Nom matière"
        android:background="@android:drawable/edit_text"
        android:padding="10dp"
        android:layout_marginTop="10dp"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"/>

    <EditText
        android:id="@+id/etUe"
        android:hint="UE"
        android:padding="10dp"
        android:layout_marginTop="8dp"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"/>

    <EditText
        android:id="@+id/etProf"
        android:hint="Professeur"
        android:padding="10dp"
        android:layout_marginTop="8dp"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"/>

    <EditText
        android:id="@+id/etVolume"
        android:hint="Volume horaire"
        android:inputType="number"
        android:padding="10dp"
        android:layout_marginTop="8dp"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"/>

    <Button
        android:id="@+id/btnAjouter"
        android:text="Ajouter Matière"
        android:backgroundTint="#3498DB"
        android:textColor="#FFFFFF"
        android:layout_marginTop="12dp"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"/>

    <TextView
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:text="Liste des matières"
        android:textStyle="bold"
        android:paddingTop="15dp"/>

    <ListView
        android:id="@+id/listMatieres"
        android:layout_width="match_parent"
        android:layout_height="match_parent"
        android:dividerHeight="8dp"/>
</LinearLayout>