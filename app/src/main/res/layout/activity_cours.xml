<?xml version="1.0" encoding="utf-8"?>

<ScrollView xmlns:android="http://schemas.android.com/apk/res/android"
    android:layout_width="match_parent"
    android:layout_height="match_parent">

    <TextView
        android:id="@+id/txtStatistiquesTitre"
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:text="Statistiques"
        android:textSize="24sp"
        android:textStyle="bold"
        android:layout_marginTop="25dp"/>

    <TextView
        android:id="@+id/txtHeuresEffectuees"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:text="Heures effectuées : 0 h"
        android:textSize="18sp"
        android:layout_marginTop="10dp"/>

    <TextView
        android:id="@+id/txtHeuresRestantes"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:text="Heures restantes : 36 h"
        android:textSize="18sp"/>

    <ProgressBar
        android:id="@+id/progressHeures"
        style="?android:attr/progressBarStyleHorizontal"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:max="36"
        android:progress="0"
        android:layout_marginTop="10dp"/>

    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:orientation="vertical"
        android:padding="20dp">

        <TextView
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="Ajouter un cours"
            android:textSize="28sp"
            android:textStyle="bold"
            android:layout_gravity="center"/>

        <Spinner
            android:id="@+id/spinnerMatiere"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginTop="20dp"/>

        <EditText
            android:id="@+id/editDate"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:hint="Date : 19/05/2026"/>

        <EditText
            android:id="@+id/editHeure"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:hint="Heure début : 08:00"/>

        <EditText
            android:id="@+id/editDuree"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:inputType="number"
            android:hint="Durée"/>

        <EditText
            android:id="@+id/editContenu"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:hint="Contenu du cours"/>

        <Button
            android:id="@+id/btnAjouter"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:text="Ajouter"
            android:layout_marginTop="20dp"/>

    </LinearLayout>

</ScrollView>